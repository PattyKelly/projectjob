function loadAllJsonMonthlyData_() {
  try {
    const folderIds = [SHARD_FOLDER_ID, SHARD_FOLDER_ID_2025];
    let allData = [];
    let fileCount = 0;
    // PENDING 3 FIX: filtrar apenas arquivos mensais — evita ler snapshots/cache (v59, v6.json)
    const MONTHLY_PATTERN = /^sherlock_logs_\d{4}-\d{2}\.json$/i;

    folderIds.forEach(id => {
      try {
        const folder = DriveApp.getFolderById(id);
        const files = folder.getFiles();
        Logger.log('[PASTA] Escaneando: ' + folder.getName());
        
        while (files.hasNext()) {
          const file = files.next();
          const name = file.getName().toLowerCase();
          const mime = file.getMimeType();

          // 1. Processa JSON — SOMENTE mensais (exclui snapshots que causam duplicacao)
          if (name.endsWith('.json')) {
            if (!MONTHLY_PATTERN.test(file.getName())) {
              Logger.log('[SKIP] ' + name + ' (nao e mensal — ignorado)');
              continue;
            }
            try {
              const content = file.getBlob().getDataAsString();
              const json = JSON.parse(content);
              if (Array.isArray(json)) {
                allData = allData.concat(json);
                fileCount++;
                Logger.log('[JSON OK] ' + name);
              }
            } catch(e) { Logger.log('[ERRO JSON] ' + name + ': ' + e); }
          } 
          // 2. Processa Google Sheets (MÃºltiplas abas)
          else if (mime === MimeType.GOOGLE_SHEETS) {
            const rows = readYearlySummarySheet_(file.getId());
            if (rows.length > 0) {
              allData = allData.concat(rows);
              fileCount++;
              Logger.log('[SHEET OK] ' + name + ' (' + rows.length + ' linhas)');
            }
          }
          // 3. Processa CSV — pula se ja ha dados suficientes (evita timeout com arquivos 90MB+)
          else if (name.endsWith('.csv') || mime === MimeType.CSV) {
            if (allData.length > 5000) {
              Logger.log('[SKIP CSV] ' + name + ' (dados suficientes de JSON/Sheets — ignorado)');
              continue;
            }
            const rows = readYearlySummaryCsv_(file);
            if (rows.length > 0) {
              allData = allData.concat(rows);
              fileCount++;
              Logger.log('[CSV OK] ' + name + ' (' + rows.length + ' linhas)');
            }
          }
        }
      } catch(folderErr) {
        Logger.log('[ERRO PASTA] ' + id + ': ' + folderErr);
      }
    });

    Logger.log('[OK] Carregados ' + fileCount + ' arquivos (' + allData.length + ' registros brutos totais)');
    return { success: true, data: allData, fileCount: fileCount };
  } catch(e) {
    Logger.log('[ERRO] loadAllJsonMonthlyData_ falhou: ' + e);
    return { success: false, error: e.toString(), data: [] };
  }
}

