function sumTrendRange_(trendMap, dateFrom, dateTo) {
  let total = 0;
  const start = dateFrom || '0000-01-01';
  const end = dateTo || '9999-12-31';
  const keys = Object.keys(trendMap || {});
  for (let i = 0; i < keys.length; i++) {
    const k = keys[i];
    if (k >= start && k <= end) {
      total += Number(trendMap[k]) || 0;
    }
  }
  return total;
}

